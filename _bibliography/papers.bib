@article{arastounia2013automatic,
  title = {Automatic extraction of insulators from 3D LiDAR data of an electrical substation},
  author = {Arastounia, Mostafa and Lichti, D.},
  year = {2013},
  journal = {ISPRS Annals of the Photogrammetry, Remote Sensing and Spatial Information Sciences},
  pages = {19-24},
