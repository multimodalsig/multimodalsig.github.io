@article{aldurgham2016toward,
  title = {Toward an Automatic Calibration of Dual Fluoroscopy Imaging Systems},
  author = {Al-Durgham, Kaleel and Lichti, D. and Kuntze, G. and Sharma, G. and Ronsky, J.},
